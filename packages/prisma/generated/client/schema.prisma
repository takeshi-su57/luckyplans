generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

enum WorkerStatus {
  ACTIVE
  DISABLED
  QUARANTINED
}

enum WorkerCredentialStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum EdgeEnrollmentTokenStatus {
  ACTIVE
  REVOKED
}

enum SearchStrategy {
  GRID
  OPTUNA
}

enum BacktestTaskStatus {
  AWAIT
  ASSIGNED
  PROCESSING
  DONE
  FAILED
  CANCELLED
}

enum WorkerUpgradeStatus {
  IDLE
  UPGRADE_PENDING
  DOWNLOADING
  VERIFYING
  RESTARTING
  SUCCEEDED
  FAILED
  ROLLED_BACK
}

enum UpgradeCampaignStatus {
  RUNNING
  PAUSED
  SUCCEEDED
  FAILED
  ROLLED_BACK
}

enum UpgradeCampaignWorkerStatus {
  PENDING
  IN_PROGRESS
  SUCCEEDED
  FAILED
  ROLLED_BACK
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  email     String
  firstName String?
  lastName  String?
  avatarUrl String?
  bio       String?
  headline  String?
  location  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects        Project[]
  skills          Skill[]
  experiences     Experience[]
  socialLinks     SocialLink[]
  skillCategories SkillCategory[]
  education       Education[]
  certifications  Certification[]
  languages       Language[]
  awards          Award[]
  hobbies         Hobby[]

  @@map("profiles")
}

model SocialLink {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  platform  String
  url       String
  label     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("social_links")
}

model SkillCategory {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  skills Skill[]

  @@unique([profileId, name])
  @@map("skill_categories")
}

enum Proficiency {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

model Project {
  id          String   @id @default(cuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title       String
  description String?
  images      String[]
  liveUrl     String?
  repoUrl     String?
  tags        String[]
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("projects")
}

model Skill {
  id          String         @id @default(cuid())
  profileId   String
  profile     Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String
  categoryId  String?
  category    SkillCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  proficiency Proficiency    @default(INTERMEDIATE)
  sortOrder   Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("skills")
}

model Experience {
  id          String    @id @default(cuid())
  profileId   String
  profile     Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  company     String
  role        String
  description String[]
  startDate   DateTime
  endDate     DateTime?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("experiences")
}

model Education {
  id          String    @id @default(cuid())
  profileId   String
  profile     Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  school      String
  degree      String?
  field       String?
  startDate   DateTime
  endDate     DateTime?
  description String[]
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("education")
}

model Certification {
  id         String    @id @default(cuid())
  profileId  String
  profile    Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name       String
  issuer     String
  issueDate  DateTime?
  expiryDate DateTime?
  url        String?
  sortOrder  Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@map("certifications")
}

model Language {
  id          String   @id @default(cuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String
  proficiency String   @default("Conversational")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("languages")
}

model Award {
  id          String    @id @default(cuid())
  profileId   String
  profile     Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title       String
  issuer      String?
  date        DateTime?
  description String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("awards")
}

model Hobby {
  id          String   @id @default(cuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name        String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("hobbies")
}

model Worker {
  id                     String                  @id @default(cuid())
  name                   String
  deviceNumber           String?                 @unique
  platform               String?
  arch                   String?
  version                String?
  status                 WorkerStatus            @default(ACTIVE)
  lastSeenAt             DateTime?
  consecutiveFailures    Int                     @default(0)
  quarantinedAt          DateTime?
  targetVersion          String?
  upgradeStatus          WorkerUpgradeStatus     @default(IDLE)
  upgradeMessage         String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  credentials            WorkerCredential[]
  upgradeCampaignWorkers UpgradeCampaignWorker[]

  @@index([status])
  @@index([lastSeenAt])
  @@map("workers")
}

model EdgeRelease {
  id                 String   @id @default(cuid())
  version            String   @unique
  windowsUrl         String
  linuxUrl           String
  checksum           String
  signature          String
  signatureAlgorithm String   @default("ed25519")
  signingKeyId       String?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("edge_releases")
}

model UpgradeCampaign {
  id               String                  @id @default(cuid())
  targetVersion    String
  previousVersion  String?
  forceMode        Boolean                 @default(false)
  phaseSize        Int                     @default(1)
  currentPhase     Int                     @default(0)
  successThreshold Float                   @default(1)
  failureThreshold Float                   @default(0.5)
  status           UpgradeCampaignStatus   @default(RUNNING)
  workers          UpgradeCampaignWorker[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@index([status, targetVersion])
  @@map("upgrade_campaigns")
}

model UpgradeCampaignWorker {
  id         String                      @id @default(cuid())
  campaignId String
  campaign   UpgradeCampaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  workerId   String
  worker     Worker                      @relation(fields: [workerId], references: [id], onDelete: Cascade)
  phase      Int
  status     UpgradeCampaignWorkerStatus @default(PENDING)
  message    String?
  createdAt  DateTime                    @default(now())
  updatedAt  DateTime                    @updatedAt

  @@unique([campaignId, workerId])
  @@index([campaignId, phase, status])
  @@map("upgrade_campaign_workers")
}

model WorkerCredential {
  id        String                 @id @default(cuid())
  workerId  String
  worker    Worker                 @relation(fields: [workerId], references: [id], onDelete: Cascade)
  keyPrefix String                 @unique
  keyHash   String
  status    WorkerCredentialStatus @default(ACTIVE)
  expiresAt DateTime?
  rotatedAt DateTime?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  @@index([workerId, status])
  @@map("worker_credentials")
}

model EdgeEnrollmentToken {
  id          String                    @id @default(cuid())
  label       String?
  tokenPrefix String                    @unique
  tokenHash   String
  status      EdgeEnrollmentTokenStatus @default(ACTIVE)
  expiresAt   DateTime?
  maxUses     Int?
  usedCount   Int                       @default(0)
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  @@index([status, expiresAt])
  @@map("edge_enrollment_tokens")
}

model StrategyTemplate {
  id            String         @id @default(cuid())
  name          String
  category      String?
  factoryConfig Json
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tasks         BacktestTask[]

  @@map("strategy_templates")
}

model BacktestTask {
  id                  String             @id @default(cuid())
  strategyTemplateId  String
  strategyTemplate    StrategyTemplate   @relation(fields: [strategyTemplateId], references: [id], onDelete: Cascade)
  name                String
  symbol              String
  interval            String
  startDate           DateTime
  endDate             DateTime
  searchStrategy      SearchStrategy
  optimizationParams  Json
  optimizationMetrics String[]
  trials              Int
  status              BacktestTaskStatus @default(AWAIT)
  assignedWorkerId    String?
  leaseExpiresAt      DateTime?
  lastHeartbeat       DateTime?
  totalConfigs        Int?
  processedConfigs    Int?
  currentConfig       String?
  trialProgress       String?
  bestConfigIds       String[]
  errorMessage        String?
  startedAt           DateTime?
  completedAt         DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  results             BacktestResult[]

  @@index([status, assignedWorkerId])
  @@index([leaseExpiresAt])
  @@map("backtest_tasks")
}

model BacktestResult {
  id             String       @id @default(cuid())
  taskId         String
  task           BacktestTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  configId       String
  strategyConfig Json
  metrics        Json
  resultFolder   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([taskId, configId])
  @@map("backtest_results")
}
