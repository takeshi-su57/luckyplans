# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# API Gateway
API_GATEWAY_PORT=3001
CORS_ORIGIN=http://localhost:3000

# Frontend
# Next.js runs on port 3000 (default). Rewrites in next.config.ts proxy
# /auth/* and /graphql to the gateway — no reverse proxy needed.
WEB_PORT=3000
API_GATEWAY_URL=http://localhost:3001

# URL baked into the web image at build time for k3d/k8s deployments
# (browser-facing, routed through the ingress — not the internal service URL)
WEB_GRAPHQL_URL=/graphql

# Environment
NODE_ENV=development

# Keycloak (api-gateway)
# Issuer URL must match the `iss` claim in Keycloak tokens
KEYCLOAK_ISSUER=http://localhost:8080/realms/luckyplans
KEYCLOAK_JWKS_URI=http://localhost:8080/realms/luckyplans/protocol/openid-connect/certs
KEYCLOAK_CLIENT_ID=luckyplans-frontend
KEYCLOAK_CLIENT_SECRET=dev-client-secret
KEYCLOAK_ADMIN_URL=http://localhost:8080

# Gateway session management
# SESSION_SECRET: run `openssl rand -base64 32` to generate
SESSION_SECRET=
SESSION_TTL_SECONDS=36000
