# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# API Gateway
API_GATEWAY_PORT=3001

# Frontend
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:3001/graphql
WEB_PORT=3000
# URL baked into the web image at build time for k3d/k8s deployments
# (browser-facing, routed through the ingress — not the internal service URL)
WEB_GRAPHQL_URL=http://localhost/graphql

# Environment
NODE_ENV=development
