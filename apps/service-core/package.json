    "@nestjs/microservices": "^11.0.0",
    "@opentelemetry/api": "^1.9.0",
    "@prisma/adapter-pg": "^7.5.0",
    "ioredis": "^5.3.0",
    "nestjs-pino": "^4.6.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@luckyplans/config": "workspace:*",
    "@nestjs/cli": "^11.0.17",
    "@nestjs/schematics": "^11.0.10",
