{
  "name": "luckyplans",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "setup": "bash infrastructure/scripts/setup.sh",
    "dev": "dotenv -e .env -- turbo run dev",
    "build": "dotenv -e .env -v NODE_ENV=production -- turbo run build",
    "lint": "dotenv -e .env -- turbo run lint",
    "test": "dotenv -e .env -- turbo run test",
    "type-check": "dotenv -e .env -- turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "clean": "turbo run clean && node -e \"require('fs').rmSync('node_modules',{recursive:true,force:true})\"",
    "deploy:local": "bash infrastructure/scripts/deploy-local.sh",
    "deploy:teardown": "bash infrastructure/scripts/teardown.sh",
    "deploy:status": "bash infrastructure/scripts/status.sh"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "prettier": "^3.2.5",
    "turbo": "^2.9.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "hono": ">=4.12.4",
      "@hono/node-server": ">=1.19.10",
      "minimatch": ">=10.2.3",
      "tar": ">=7.5.11",
      "effect": ">=3.20.0",
      "path-to-regexp": ">=8.4.0",
      "picomatch": ">=4.0.4"
    }
  }
}
